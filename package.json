{
  "name": "saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "guard": "tsx scripts/architecture-guard.ts",
    "guard:ci": "tsx scripts/architecture-guard.ts --ci",
    "guard:verbose": "tsx scripts/architecture-guard.ts --verbose",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "ANALYZE=true next build --webpack",
    "docs:gen": "tsx scripts/doc-gen.ts",
    "docs:check": "tsx scripts/doc-gen.ts --validate",
    "supabase:types": "supabase gen types --linked --lang=typescript --schema public > types/supabase.ts",
    "monitor:cash": "supabase db query --linked \"SELECT session_date, status, opening_cash, expected_cash, real_cash_detail, active_entries_count, income_count, expense_count FROM cash_session_summary ORDER BY session_date DESC LIMIT 5;\""
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@types/jspdf": "^1.3.3",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "madge": "^8.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
