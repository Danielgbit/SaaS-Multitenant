# =============================================================================
# NEVER commit real secrets to version control.
# This file documents required variables only — use placeholders.
# Copy to .env.local and fill with real values.
# =============================================================================

# =============================================================================
# SUPABASE — Autenticación, Base de Datos, Realtime
# =============================================================================
# Required: dev y producción
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# STRIPE — Pagos y Suscripciones
# =============================================================================
# Required solo si trabajas con billing (opcional en dev)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PRICE_BASIC_MONTHLY=price_basic
STRIPE_PRICE_PRO_MONTHLY=price_pro
# STRIPE_WEBHOOK_SECRET=whsec_your-secret

# =============================================================================
# RESEND — Emails Transaccionales
# =============================================================================
# Required: envío de invitaciones, confirmaciones y recordatorios
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# PROVIDERS — Credenciales de Webhooks (n8n / Wasender)
# =============================================================================
# Required si usas n8n o Wasender como proveedor de notificaciones
# WASENDER_WEBHOOK_TOKEN=your-wasender-token
# WEBHOOK_SECRET=your-n8n-webhook-secret

# =============================================================================
# CRON — Autenticación de Endpoints Programados
# =============================================================================
# Required en producción. Usar un valor seguro (uuid o hash largo).
# Debe coincidir con la config de cron-job.org / Vercel Cron.
CRON_SECRET=your-cron-secret

# Opcional: modo dry-run para el worker process-notifications
# PROCESS_NOTIFICATIONS_DRY_RUN=false

# =============================================================================
# CRON — Expuesto al frontend admin (botones reintentar/reprocesar)
# =============================================================================
# Required si usas la UI admin de notificaciones
# NEXT_PUBLIC_CRON_SECRET=your-cron-secret

# =============================================================================
# ENTORNO — URLs Públicas
# =============================================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Opcional: URL pública para webhooks/cron (ej: ngrok o dominio real)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# =============================================================================
# FEATURE FLAGS — Desarrollo y Shadow Mode
# =============================================================================
# BYPASS — Solo para desarrollo local. NUNCA activar en producción.
BYPASS_SUBSCRIPTION_CHECK=true
BYPASS_ADMIN_AUTH=true

# Shadow Mode — Validación en paralelo de nueva arquitectura event-driven
# observe_only = logs sin impacto; enforce = bloquea si hay discrepancia
SHADOW_MODE_ENABLED=true
SHADOW_MODE_FLOWS=service:complete,appointment:cancel
SHADOW_MODE=observe_only

# Shadow Notifications — Validación de cola de notificaciones v2
SHADOW_NOTIFICATION_ENABLED=true
SHADOW_NOTIFICATION_MODE=observe_only
SHADOW_BATCH_SIZE=20
SHADOW_PROCESSING_TIMEOUT_MIN=5
SHADOW_SCHEDULING_TOLERANCE_SEC=60
